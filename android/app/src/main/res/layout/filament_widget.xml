<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="0dp">

    <!-- Rainbow Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:orientation="horizontal">
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#FF5252" />
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#FF9800" />
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#FFEB3B" />
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#4CAF50" />
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#2196F3" />
        <View android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:background="#9C27B0" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header -->
        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filament Tracker"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Stats -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bestand:"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0g"
                android:textColor="#00BCD4"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Spulen:"
                android:textColor="#888888"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_spool_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="0"
                android:textColor="#00BCD4"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Warning -->
        <TextView
            android:id="@+id/widget_low_stock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="✓ Alle OK"
            android:textColor="#4CAF50"
            android:textSize="11sp"
            android:textAlignment="center"
            android:padding="6dp"
            android:background="@drawable/widget_warning_bg" />

    </LinearLayout>

</LinearLayout>
